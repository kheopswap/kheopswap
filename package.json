{
	"name": "kheopswap",
	"version": "1.0.0",
	"description": "",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"test": "pnpm --filter web test",
		"build": "pnpm --filter web build",
		"preview": "pnpm --filter web preview",
		"dev": "pnpm --filter web dev",
		"clean": "git clean -fdx",
		"typecheck": "pnpm --filter web typecheck",
		"check": "biome check --write",
		"knip": "knip",
		"papi": "papi",
		"papi:build": "papi --whitelist papi-whitelist.ts",
		"fetch-tokens": "cd web && node --experimental-transform-types --env-file-if-exists=.env.local scripts/fetch-tokens.ts",
		"postinstall": "papi",
		"prepare": "simple-git-hooks"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm biome check --staged --error-on-warnings --no-errors-on-unmatched"
	},
	"keywords": [],
	"author": "Kheops",
	"license": "AGPL",
	"packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"knip": "^6.16.1",
		"polkadot-api": "2.1.6",
		"simple-git-hooks": "^2.13.1"
	},
	"dependencies": {
		"@polkadot-api/descriptors": "file:.papi/descriptors"
	}
}
