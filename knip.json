{
	"$schema": "./node_modules/knip/schema.json",
	"workspaces": {
		".": {
			"entry": ["papi-whitelist.ts"],
			"project": []
		},
		"web": {
			"entry": ["scripts/fetch-tokens.ts", "src/**/*.test.{ts,tsx}"],
			"project": ["src/**/*.{ts,tsx}"],
			"ignoreDependencies": ["tailwindcss"],
			"ignore": ["src/types/helpers.ts"]
		}
	},
	"tags": ["-knipignore"],
	"ignoreExportsUsedInFile": true
}
